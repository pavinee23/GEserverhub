{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/customer-dashboard-login",
      "destination": "https://strong-dory-enabled.ngrok-free.app/customer-dashboard-login",
      "permanent": false
    },
    {
      "source": "/customer-dashboard",
      "destination": "https://strong-dory-enabled.ngrok-free.app/customer-dashboard",
      "permanent": false
    },
    {
      "source": "/energy-dashboard-login",
      "destination": "https://strong-dory-enabled.ngrok-free.app/energy-dashboard-login",
      "permanent": false
    },
    {
      "source": "/energy-dashboard",
      "destination": "https://strong-dory-enabled.ngrok-free.app/energy-dashboard",
      "permanent": false
    },
    {
      "source": "/energy-dashboard/:path*",
      "destination": "https://strong-dory-enabled.ngrok-free.app/energy-dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/cargo/track",
      "destination": "https://strong-dory-enabled.ngrok-free.app/cargo/track",
      "permanent": false
    },
    {
      "source": "/cargo/:path*",
      "destination": "https://strong-dory-enabled.ngrok-free.app/cargo/:path*",
      "permanent": false
    }
  ]
}

