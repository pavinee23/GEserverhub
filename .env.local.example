# ── Backend ──────────────────────────────────────────────────────────
# URL ของ Python backend (gunicorn) — ใช้ใน server-side Next.js
BACKEND_URL=https://api.yourdomain.com

# URL ที่ browser เรียกตรง (ถ้ามี public endpoint)
NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# ── Database (Prisma / NextAuth) ─────────────────────────────────────
DATABASE_URL="mysql://user:password@host:3306/goeunserverhub"

# ── NextAuth ─────────────────────────────────────────────────────────
# สร้างด้วย: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=https://yourdomain.com

